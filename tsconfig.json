{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@wc/shared-types": ["./packages/shared-types/src/index.ts"],
      "@wc/agent-core": ["./packages/agent-core/src/index.ts"]
    }
  },
  "include": ["apps/*/src", "packages/*/src"],
  "comment": "apps/web has its own Next.js tsconfig (jsx/dom); exclude it from the node workspace typecheck.",
  "exclude": ["apps/web"]
}
